#
# Add the following if statement to your .bashrc.user
# # Set the bash prompt PS1
# if [ -e /$HOME/.bash_prompt ]; then
#     source /$HOME/.bash_prompt
# fi

# =========================
# Safe Color Definitions
# =========================

COLOR_NC='\[\e[0m\]'
COLOR_GREEN='\[\e[0;32m\]'
COLOR_YELLOW='\[\e[0;33m\]'
COLOR_RED='\[\e[0;31m\]'
COLOR_CYAN='\[\e[0;36m\]'

# =========================
# Default Override Hooks
# =========================

get_hostname() { :; }
sourced_file() { :; }

# =========================
# VIM Marker
# =========================

am_i_vim() {
    [[ -n $VIM ]] && printf '%s+%s' "$COLOR_RED" "$COLOR_NC" || printf '$'
}

# =========================
# Git Branch (safe + fast)
# =========================

parse_git_branch() {
    local branch
    branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || \
    branch=$(git rev-parse --short HEAD 2>/dev/null) || \
    return

    printf '%s' "$branch"
}

# =========================
# Compact Path (last 3 parts)
# =========================

update_three_directories() {
    local hpwd

    case $PWD in
        "$HOME") hpwd="~" ;;
        "$HOME"/*/*) hpwd="${PWD#"${PWD%/*/*}/"}" ;;
        "$HOME"/*) hpwd="~/${PWD##*/}" ;;
        /*/*/*) hpwd="${PWD#"${PWD%/*/*/*}/"}" ;;
        *) hpwd="$PWD" ;;
    esac

    printf '%s' "$hpwd"
}

# =========================
# Prompt Builder
# =========================

build_prompt() {
    local host src branch dirs vimmark

    host=$(get_hostname)
    src=$(sourced_file)
    branch=$(parse_git_branch)
    dirs=$(update_three_directories)
    vimmark=$(am_i_vim)

    PS1="${COLOR_GREEN}[\A]${COLOR_NC} ${host}${src} \
${COLOR_YELLOW}${branch}${COLOR_NC} [${dirs}]${vimmark} "
}

PROMPT_COMMAND=build_prompt
PS2="${COLOR_GREEN}[\A]${COLOR_NC} ${COLOR_YELLOW}>${COLOR_NC} "
